# Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL_NAME=gemini-3.1-flash-lite-preview

# Supabase
# Get from Supabase Dashboard:
# - SUPABASE_PROJECT_REF: from project URL (https://supabase.com/dashboard/project/<ref>)
# - SUPABASE_URL: Project Settings → Data API → Project URL
# - SUPABASE_ANON_KEY: Project Settings → Data API → anon/publishable key
# - SUPABASE_SERVICE_ROLE_KEY: Project Settings → Data API → service_role key (backend only)
SUPABASE_PROJECT_REF=https://uiscrloheggjvnxchwpl.supabase.co
SUPABASE_URL=https://uiscrloheggjvnxchwpl.supabase.co
SUPABASE_ANON_KEY=sb_publishable_GseC-pbb3B5L7qyUpBblfw_pEH1yBx5
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InVpc2NybG9oZWdnanZueGNod3BsIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3NTIxNTEwMSwiZXhwIjoyMDkwNzkxMTAxfQ.p0NPmuKPIQghgBu4gB5tSLRDJTwCr-KNM-hZFbg2RHk

# Database
# Local fallback (default if DATABASE_URL is unset): sqlite:///./room404.db
# Supabase pooled example:
# DATABASE_URL=postgresql+psycopg://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
# Supabase direct example:
# DATABASE_URL=postgresql://postgres:<PASSWORD>@db.<project-ref>.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Frontend origins
# Comma-separated (no spaces required)
# Example: http://localhost:5173,https://your-frontend.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:5173

# MVP manager access fallback key (used by manager analytics endpoints)
MANAGER_DASHBOARD_KEY=manager-dev-key
