# Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL_NAME=gemini-3.1-flash-lite-preview

# Optional app-level Supabase values (if your backend/frontend code uses them)
SUPABASE_PROJECT_REF=your_project_ref
SUPABASE_URL=https://your_project_ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Database
# Local fallback (default if DATABASE_URL is unset): sqlite:///./room404.db
# Supabase pooled example:
# DATABASE_URL=postgresql+psycopg://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
# Supabase direct example:
# DATABASE_URL=postgresql://postgres:<PASSWORD>@db.<project-ref>.supabase.co:5432/postgres
DATABASE_URL=

# Frontend origins
# Comma-separated (no spaces required)
# Example: http://localhost:5173,https://your-frontend.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Task assignment cooldown in minutes
STAFF_COOLDOWN_MINUTES=20

# MVP manager access fallback key (used by manager analytics endpoints)
MANAGER_DASHBOARD_KEY=manager-dev-key
